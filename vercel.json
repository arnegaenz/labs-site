{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/sync/ad-metrics",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/webhooks/store-reviews",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/sync/weekly-creative-review",
